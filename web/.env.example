# Agent Eval 可观测平台 — 环境变量样例（§12.3）
#
# 拷贝为 .env 并按需修改；docker compose 默认即用 compose 内置值起栈。
# 生产部署务必替换所有 *-change-me 密钥，并通过 secrets manager 注入。

# ── 数据库 ──
# PG 连接串；serverless 经 PgBouncer 时追加 ?pgbouncer=true&connection_limit=1
PLATFORM_DATABASE_URL=postgresql://eval:evalpassword@localhost:5432/agent_eval?schema=public

# ── 对象存储 ──
PLATFORM_OBJECT_STORAGE=minio            # minio | s3 | cos
PLATFORM_S3_ENDPOINT=http://localhost:9000
PLATFORM_S3_REGION=us-east-1
PLATFORM_S3_BUCKET=agent-eval
PLATFORM_S3_ACCESS_KEY=eval
PLATFORM_S3_SECRET_KEY=evalpassword123
PLATFORM_S3_PATH_STYLE=true              # MinIO 需 true；AWS S3 通常 false

# ── 密钥 ──
PLATFORM_JWT_SECRET=dev-insecure-jwt-secret-change-me          # JWT 签名密钥
PLATFORM_KEY_ENCRYPTION_KEY=dev-insecure-encryption-key-change-me  # API Key secret 对称加密密钥（§6.3 方案 A）

# ── 业务开关 ──
PLATFORM_ALLOW_SIGNUP=true               # 是否开放注册（内部部署可关闭）

# ── 摄取（Ingestion，Sprint 7d）──
PLATFORM_INGEST_RATE_LIMIT=600           # 每 key 每分钟配额
PLATFORM_INGEST_MAX_BATCH=500            # 单批事件数上限
PLATFORM_INGEST_MAX_BYTES=4194304        # 单批体积上限（4MB）

# ── 杂项 ──
PLATFORM_PRESIGN_TTL_SEC=900             # presigned URL 有效期（秒，≤900）
PLATFORM_RETENTION_DEFAULT_DAYS=90       # 项目默认保留期
LOG_LEVEL=info                           # trace|debug|info|warn|error

# ── 评估器侧（ResultSink，Sprint 7e；此处仅参考）──
# AGENT_EVAL_HOST=http://localhost:3000
# AGENT_EVAL_PUBLIC_KEY=pk-eval-xxxx
# AGENT_EVAL_SECRET_KEY=sk-eval-xxxx
# AGENT_EVAL_PROJECT=<project-uuid-or-slug>
# AGENT_EVAL_UPLOAD=true
