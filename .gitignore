# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/

# Virtual environment
.venv/

# Environment variables
.env

# User LLM config (contains API keys)
llm_config.yaml

# IDE
.idea/
.vscode/

# Claude Code
.claude/
*.swp
*.swo

# Testing
.pytest_cache/
htmlcov/
.coverage
coverage.xml

# Runtime data (not version controlled)
workspace/
packages/

# OS
.DS_Store
Thumbs.db

# Ruff
.ruff_cache/

# mypy
.mypy_cache/

# Web Portal (Node.js build artifacts)
web/backend/node_modules/
web/frontend/node_modules/
web/frontend/dist/
web/backend/public/

# 可观测平台离线摄取队列（运行期产物）
.ingest_queue/

# llm_config.yaml 不落根目录（真实配置在 evaluator/assets/configs/）
/llm_config.yaml
# evaluator 真实配置（保留 .example）
evaluator/agent_eval/assets/configs/llm_config.yaml

# 覆盖全局 gitignore 的 *.md 规则——项目文档（*.md）必须纳入版本控制
!*.md

# 覆盖全局 gitignore 的 datasets 规则——agent_eval/datasets 是源码包，assets/datasets 是随包索引
!evaluator/agent_eval/datasets/
!evaluator/agent_eval/assets/datasets/
