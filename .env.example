# ============================================================
# Agent Eval System 环境变量配置
# ============================================================
#
# 使用方法:
#   cp .env.example .env
#   然后修改 .env 中的配置值
#
# 适用范围说明:
#   [评估器]    - Python CLI（agent-eval eval）与 ResultSink 需要
#   [平台后端]  - 可观测平台 Express 后端（web/backend）需要
#   [基础设施]  - docker compose 起栈的 postgres / minio 容器需要
#
# 配置优先级:
#   1. 环境变量（最高优先级，用于生产部署）
#   2. .env 文件（本地开发）
#   3. 代码默认值（未配置项自动使用，见 agent_eval/config 与 web/backend/src/config）
#
# 单一配置源 & 去重约定:
#   - 数据库凭据只在 [4] 写一次（POSTGRES_*）；应用用的 PLATFORM_DATABASE_URL
#     由 docker-compose.yml 自动拼接（容器内 host=postgres），不在本文件重复。
#   - 对象存储凭据只在 [5] 写一次（MINIO_ROOT_* = S3 access/secret）；
#     PLATFORM_S3_ACCESS_KEY / SECRET_KEY / ENDPOINT 由 compose 自动派生。
#   - host 直跑后端时，需自行 export PLATFORM_DATABASE_URL / PLATFORM_S3_*
#     （可由本文件 [4]/[5] 拼接；见文末「host 直跑速查」）。
# ============================================================


# ============================================================
# [1] LLM Provider API Key [评估器]  (评估必填)
# ============================================================
# 评估器 LLM Judge 使用。llm_config.yaml 中以 ${DEEPSEEK_API_KEY} 等引用。
# 按实际启用的 Provider 配置，不用的留空。

# DeepSeek（默认 Judge Provider）
DEEPSEEK_API_KEY=

# Kimi（视觉评估 Provider，可选）
KIMI_API_KEY=

# OpenAI（可选备选）
# OPENAI_API_KEY=


# ============================================================
# [2] Langfuse 追踪 [评估器]  (可选)
# ============================================================
# 记录 LLM 调用链（trace/span）；留空则禁用追踪。
# 注册 https://cloud.langfuse.com 获取密钥。
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com


# ============================================================
# [3] 可观测平台对接（ResultSink）[评估器]  (可选)
# ============================================================
# agent-eval eval 完成后自动把结果推送到可观测平台。
# 凭据在平台「项目详情 → API Keys → 签发新 Key」获取（secret 仅显示一次）。
# 未配置或 AGENT_EVAL_UPLOAD!=true → 静默跳过，零开销。

# 平台地址（本地后端 :9000；docker compose 起栈同此）
AGENT_EVAL_HOST=http://localhost:9000

# API Key（公钥 / 密钥）
AGENT_EVAL_PUBLIC_KEY=
AGENT_EVAL_SECRET_KEY=

# 目标项目（id 或 slug；留空 = Key 所属项目）
# AGENT_EVAL_PROJECT=

# eval 完成后是否自动上报（CLI --upload / --no-upload 可覆盖）
AGENT_EVAL_UPLOAD=true

# 离线队列目录（默认 <workspace>/.ingest_queue）
# AGENT_EVAL_QUEUE_DIR=


# ============================================================
# [4] 数据库 [平台后端 + 基础设施]  (必须 — 单一凭据源)
# ============================================================
# 这三项同时供 postgres 容器初始化 与 平台后端连接使用。
# 应用所需 PLATFORM_DATABASE_URL 由 docker-compose.yml 自动拼接：
#   postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}?schema=public
# 故本文件不再单独维护 PLATFORM_DATABASE_URL（避免与下面三项重复）。
# 迁移到云数据库时：改这三项为云库的 user/password/db 即可。
POSTGRES_USER=eval
POSTGRES_PASSWORD=evalpassword
POSTGRES_DB=agent_eval


# ============================================================
# [5] 对象存储 [平台后端 + 基础设施]  (必须 — 单一凭据源)
# ============================================================
# minio（本地，docker compose）/ s3 / cos（腾讯云）。
# 迁移到 COS 见 docs/arch/09 §12.2：仅改本段，代码与 Dockerfile 不动。
#
# 凭据去重：MINIO_ROOT_USER / MINIO_ROOT_PASSWORD 既是 minio 容器 root 凭据，
# 也是平台 S3 access/secret（compose 自动派生 PLATFORM_S3_ACCESS_KEY/SECRET_KEY）。
# 容器内 PLATFORM_S3_ENDPOINT 由 compose 设为 http://minio:9000，不在本文件维护。
PLATFORM_OBJECT_STORAGE=minio
PLATFORM_S3_REGION=us-east-1
PLATFORM_S3_BUCKET=agent-eval
PLATFORM_S3_PATH_STYLE=true              # MinIO 需 true；AWS S3 通常 false

# MinIO root 凭据（= S3 access key / secret key）；生产用 COS 时改为 COS 的 SecretId/SecretKey
MINIO_ROOT_USER=eval
MINIO_ROOT_PASSWORD=evalpassword123


# ============================================================
# [6] 安全与密钥 [平台后端]  (生产必须替换)
# ============================================================
# 生成强随机值: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PLATFORM_JWT_SECRET=

# API Key secret 对称加密密钥（§6.3 方案 A，验签用）
PLATFORM_KEY_ENCRYPTION_KEY=

# 是否开放注册（内部部署可关闭）
PLATFORM_ALLOW_SIGNUP=true


# ============================================================
# [7] 摄取与业务参数 [平台后端]  (可选，保持默认即可)
# ============================================================
PLATFORM_INGEST_RATE_LIMIT=600           # 每 key 每分钟配额
PLATFORM_INGEST_MAX_BATCH=500            # 单批事件数上限
PLATFORM_INGEST_MAX_BYTES=4194304        # 单批体积上限（4MB）
PLATFORM_PRESIGN_TTL_SEC=900             # presigned URL 有效期（秒，≤900）
PLATFORM_RETENTION_DEFAULT_DAYS=90       # 项目默认保留期
LOG_LEVEL=info                           # trace | debug | info | warn | error

# 工作目录（runs/reports/cache/queue 输出位置；相对 CWD）
WORKSPACE_DIR=workspace


# ============================================================
# [8] SAML SSO 登录 [平台后端]  (可选)
# ============================================================
# 接入公司统一 IdP「光华平台」，与 SquadSight 平级（docs/arch/12）。
# 光华 IdP 免 SP 注册：配齐下列参数即可，无需在光华侧登记。
# 未启用（SAML_SSO_ENABLED=false）时登录页不显示 SSO Tab，邮箱登录照常。

# 是否启用 SSO
SAML_SSO_ENABLED=false

# —— SP（本平台侧）——
SAML_SP_ENTITY_ID=https://eval.bj33smarter.com/api/v1/auth/sso/metadata
SAML_ACS_URL=https://eval.bj33smarter.com/api/v1/auth/sso/acs
SAML_SLS_URL=https://eval.bj33smarter.com/api/v1/auth/sso/sls
# SP 证书/私钥（可选；光华不强制签名请求。生成：
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout sp.key -out sp.crt \
#     -days 3650 -subj "/CN=eval.bj33smaster.com"）
SAML_SP_CERT=
SAML_SP_KEY=

# —— IdP（光华侧，公开值；证书从 SquadSight 同源复用）——
SAML_IDP_ENTITY_ID=https://guanghua.53jy.net/idp/metadata
SAML_IDP_SSO_URL=https://guanghua.53jy.net/idp/login
SAML_IDP_SLS_URL=https://guanghua.53jy.net/idp/logout
# 光华公钥证书（纯 base64，无 BEGIN/END 标签亦可，后端自动补 PEM 头）
SAML_IDP_CERT=

SAML_STRICT=true
SAML_DEBUG=false


# ============================================================
# host 直跑速查（非配置项，仅供参考；compose 起栈时忽略本段）
# ============================================================
# Node 后端不自动加载 .env；host 直跑需在 shell export 下列变量（由 [4]/[5] 拼接）：
#   export PLATFORM_DATABASE_URL="postgresql://eval:evalpassword@localhost:5432/agent_eval?schema=public"
#   export PLATFORM_S3_ENDPOINT="http://localhost:9000"
#   export PLATFORM_S3_ACCESS_KEY="eval" PLATFORM_S3_SECRET_KEY="evalpassword123"
#   export PLATFORM_JWT_SECRET="..." PLATFORM_KEY_ENCRYPTION_KEY="..."
# 或用 Makefile 目标（如有 backend-dev）一键派生。
