# Agent Eval System — LLM Provider API Keys
# 复制此文件为 .env 并填入真实 Key：
#   cp .env.example .env
#
# llm_config.yaml 中使用 ${DEEPSEEK_API_KEY} 引用这些变量

# DeepSeek（默认 Judge Provider）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# OpenAI（可选备选）
# OPENAI_API_KEY=sk-your-openai-api-key-here

# Langfuse 追踪（可选 — 留空或注释掉则禁用追踪）
# 注册 https://cloud.langfuse.com 获取密钥
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://us.cloud.langfuse.com

# ──────────────────────────────────────────────────────────────────────────
# 可观测平台对接（Sprint 7e ResultSink）
# 评估完成后把结果推送到自托管可观测平台（POST /api/public/ingest，HMAC 鉴权）。
# 凭据在平台「项目详情 → API Keys → 签发新 Key」获取（secret 仅显示一次）。
# 未配置或 AGENT_EVAL_UPLOAD!=true → ResultSink 静默跳过，零开销。
# ──────────────────────────────────────────────────────────────────────────

# 平台地址（本地后端默认 :3000；docker compose 起栈同此）
AGENT_EVAL_HOST=http://localhost:3000

# API Key（在平台签发；secret 仅客户端持有，平台只存哈希）
AGENT_EVAL_PUBLIC_KEY=pk-eval-replace-with-your-public-key
AGENT_EVAL_SECRET_KEY=sk-eval-replace-with-your-secret-key

# 目标项目（项目 id 或 slug；留空则用 Key 所属项目）
# AGENT_EVAL_PROJECT=

# 是否在 eval 完成后自动上报（也可用 CLI --upload / --no-upload 覆盖）
AGENT_EVAL_UPLOAD=true

# 离线队列目录（发送失败时缓存；默认 <workspace>/.ingest_queue）
# AGENT_EVAL_QUEUE_DIR=

# ──────────────────────────────────────────────────────────────────────────
# 可观测平台后端（PLATFORM_*）
# 由 Express 后端（web/backend）读取。本地起栈建议用 docker compose
# （web/docker-compose.yml 已内置这些值）；host 直跑则需 export 这些变量。
# 生产部署务必替换所有 *-change-me 密钥，并通过 secrets manager 注入。
# ──────────────────────────────────────────────────────────────────────────

# 数据库（serverless 经 PgBouncer 时追加 ?pgbouncer=true&connection_limit=1）
PLATFORM_DATABASE_URL=postgresql://eval:evalpassword@localhost:5432/agent_eval?schema=public

# 对象存储（minio | s3 | cos）
PLATFORM_OBJECT_STORAGE=minio
PLATFORM_S3_ENDPOINT=http://localhost:9000
PLATFORM_S3_REGION=us-east-1
PLATFORM_S3_BUCKET=agent-eval
PLATFORM_S3_ACCESS_KEY=eval
PLATFORM_S3_SECRET_KEY=evalpassword123
PLATFORM_S3_PATH_STYLE=true              # MinIO 需 true；AWS S3 通常 false

# 密钥（生产务必替换）
PLATFORM_JWT_SECRET=dev-insecure-jwt-secret-change-me
PLATFORM_KEY_ENCRYPTION_KEY=dev-insecure-encryption-key-change-me  # API Key secret 对称加密密钥（§6.3 方案 A）

# 业务开关
PLATFORM_ALLOW_SIGNUP=true               # 是否开放注册（内部部署可关闭）

# 摄取（Ingestion）
PLATFORM_INGEST_RATE_LIMIT=600           # 每 key 每分钟配额
PLATFORM_INGEST_MAX_BATCH=500            # 单批事件数上限
PLATFORM_INGEST_MAX_BYTES=4194304        # 单批体积上限（4MB）

# 杂项
PLATFORM_PRESIGN_TTL_SEC=900             # presigned URL 有效期（秒，≤900）
PLATFORM_RETENTION_DEFAULT_DAYS=90       # 项目默认保留期
LOG_LEVEL=info                           # trace|debug|info|warn|error


