# EditorConfig — 跨编辑器统一缩进/换行：https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

# Makefile 必须用 tab
[Makefile]
indent_style = tab
